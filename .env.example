# Copy to `.env` and fill in values. Never commit real `.env` (secrets).
# Loaded by `node --import dotenv/config` (Temporal worker, API, Playwright scripts).

# --- OpenAI (PatientStickyNote / OHID workflow) ---
# Required for AI-generated sticky text. Must be set on the **Temporal worker** process.
OPENAI_API_KEY=
# Optional model override (default in code: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini
# Only if you must post a deterministic note without OpenAI (not recommended for production):
# OPENAI_STICKY_NOTE_TEMPLATE_FALLBACK=1

# --- Temporal (example) ---
# TEMPORAL_ADDRESS=127.0.0.1:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=availity-login-ohid2
